# kitchCU — copy to .env for local development (docker compose loads .env.example by default; override with .env for secrets)

# PostgreSQL
POSTGRES_USER=ckac
POSTGRES_PASSWORD=ckac_dev
POSTGRES_DB=ckac
DATABASE_URL=postgresql+asyncpg://ckac:ckac_dev@postgres:5432/ckac

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible media)
MINIO_ROOT_USER=ckac
MINIO_ROOT_PASSWORD=ckac_minio_dev
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=ckac-media
MINIO_PUBLIC_URL=http://localhost:9000

# JWT
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=480
JWT_REFRESH_EXPIRE_DAYS=7

# App
APP_ENV=development
CORS_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:5173,http://localhost:13000,http://localhost:13001,http://localhost:13002,http://localhost:13003

# Demo data (local dev — see scripts/seed-dev-data.py)
DEMO_OWNER_PHONE=9876543210
DEMO_OWNER_PHONE_E164=+919876543210
DEMO_OTP=123456
DEMO_KITCHEN_CODE=CKPNQ001

# Service URLs (docker network)
IDENTITY_SERVICE_URL=http://identity:8001
CATALOG_SERVICE_URL=http://catalog:8002
ORDER_SERVICE_URL=http://order:8003
BILLING_SERVICE_URL=http://billing:8004
NOTIFICATION_SERVICE_URL=http://notification:8005
MARKETING_SERVICE_URL=http://marketing:8006
RATINGS_SERVICE_URL=http://ratings:8007
GROWTH_SERVICE_URL=http://growth:8008
DELIVERY_SERVICE_URL=http://delivery:8009
LEARNING_SERVICE_URL=http://learning:8010
COMMUNITY_SERVICE_URL=http://community:8011
STREAMING_SERVICE_URL=http://streaming:8012

# Local delivery partner (platform courier) — mock by default; set http + quote URL for real API
DELIVERY_PARTNER=mock
DELIVERY_PARTNER_BASE_FEE=25
DELIVERY_PARTNER_PER_KM=12
# DELIVERY_PARTNER=http
# DELIVERY_PARTNER_QUOTE_URL=https://partner.example/quote


# LiveKit (optional — streaming works without tokens in dev)
# Prefer configuring via Super Admin → Control → Platform API keys (DB) when set;
# env below remains the bootstrap / fallback for local docker.
# LIVEKIT_URL=ws://localhost:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret
WHATSAPP_VERIFY_TOKEN=ckac-dev-verify
INTERNAL_API_KEY=dev-internal-key-change-in-production

# Razorpay (platform SaaS fallback — also configurable in Super Admin → API keys;
# per-kitchen keys live on Owner → Payment gateway)
# Platform payment keys (env bootstrap). Super-admin Control can override via
# ckac_identity.platform_api_keys (same key names: razorpay_*, livekit_*, etc.).
# Outside APP_ENV=development|test, mock Razorpay ids / free capture are disabled.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# WHATSAPP_APP_SECRET=   # Meta X-Hub-Signature-256 for inbound webhook POST

# Optional: AI support chat on marketing site (falls back to knowledge base if unset)
# SUPPORT_AI_API_KEY=
# SUPPORT_AI_MODEL=gpt-4o-mini

# Messaging wallet + risk toggles (configurable Phase-2 capabilities)
MESSAGING_FEE_PER_RECIPIENT_INR=1.0
MESSAGING_WALLET_LOW_BALANCE_INR=50
# WEBHOOK_STRESS_BURST_SIZE=500
# WEBHOOK_STRESS_MAX_CONCURRENCY=40

# Bulk seed tuning (scripts/seed-bulk-data.py, scripts/seed-all.ps1)
# CKAC_BULK_ORDERS=250
# CKAC_BULK_KITCHENS=22
# CKAC_SEED_EXTRAS=1

# Google Maps (Track embeds; also Super Admin API keys → google_maps_api_key)
# VITE_GOOGLE_MAPS_API_KEY=
# GOOGLE_MAPS_API_KEY=

# Customer social login OAuth (production — dev mode works without these)
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_FACEBOOK_CLIENT_ID=
# OAUTH_FACEBOOK_CLIENT_SECRET=
# OAUTH_INSTAGRAM_CLIENT_ID=
# OAUTH_INSTAGRAM_CLIENT_SECRET=
# OAUTH_TWITTER_CLIENT_ID=
# OAUTH_TWITTER_CLIENT_SECRET=
# CUSTOMER_OAUTH_REDIRECT_BASE=http://localhost:13001
