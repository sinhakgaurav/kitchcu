# kitchCU — production .env for the single-VM deploy (infra/gcp-vm/docker-compose.prod.yml).
# Copy to infra/gcp-vm/.env on the VM (startup.sh does this from instance metadata
# automatically — this file is just the reference template). NEVER commit the real .env.

POSTGRES_USER=ckac
POSTGRES_PASSWORD=REPLACE_ME_DB_PASSWORD
POSTGRES_DB=ckac

APP_ENV=production
CORS_ORIGINS=https://kitchcu.com,https://www.kitchcu.com,https://customer.kitchcu.com,https://kitchen.kitchcu.com,https://admin.kitchcu.com,https://api.kitchcu.com

JWT_SECRET=REPLACE_ME_JWT_SECRET
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=480
JWT_REFRESH_EXPIRE_DAYS=7

INTERNAL_API_KEY=REPLACE_ME_INTERNAL_API_KEY
WHATSAPP_VERIFY_TOKEN=REPLACE_ME_WHATSAPP_VERIFY_TOKEN

ADMIN_EMAIL=admin@kitchcu.com
ADMIN_PASSWORD=REPLACE_ME_ADMIN_PASSWORD

# Media — GCS bucket via the S3-compatible MinIO client (no app code changes).
# Create the bucket + HMAC key with the gcloud commands in docs/DEPLOYMENT-GCP.md §11.
MEDIA_STORAGE_BACKEND=minio
MINIO_ENDPOINT=storage.googleapis.com
MINIO_SECURE=true
MINIO_ACCESS_KEY=REPLACE_ME_GCS_HMAC_ACCESS_KEY
MINIO_SECRET_KEY=REPLACE_ME_GCS_HMAC_SECRET
MINIO_BUCKET=REPLACE_ME_BUCKET_NAME
MINIO_PUBLIC_URL=https://storage.googleapis.com

CUSTOMER_OAUTH_REDIRECT_BASE=https://customer.kitchcu.com

# Third-party integrations — leave blank at go-live, configure later via
# Super Admin -> Control -> API Keys (DB-backed, no redeploy needed) or per-kitchen
# Owner -> Payment Gateway page. Nothing below is required for the platform to boot.
# RAZORPAY_KEY_ID=
# RAZORPAY_KEY_SECRET=
# RAZORPAY_WEBHOOK_SECRET=
# WHATSAPP_APP_SECRET=
# LIVEKIT_URL=
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# GOOGLE_MAPS_API_KEY=
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
