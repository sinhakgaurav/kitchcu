# kitchCU — single-VM reverse proxy + automatic HTTPS (Let's Encrypt).
# One multi-SAN certificate for all public hosts (avoids burning LE's
# "5 certs per exact identifier set / 168h" limit on every redeploy).
# Do NOT delete the caddy_data volume unless certs are irrecoverably corrupt.
#
# Frontends already proxy /api/* to gateway:8000 (apps/website/nginx.*.conf).

{
	email admin@kitchcu.com
}

kitchcu.com, www.kitchcu.com, customer.kitchcu.com, kitchen.kitchcu.com, admin.kitchcu.com, api.kitchcu.com, media.kitchcu.com {
	@portal host kitchcu.com www.kitchcu.com
	handle @portal {
		reverse_proxy portal-web:80
	}

	@customer host customer.kitchcu.com
	handle @customer {
		reverse_proxy customer-web:80
	}

	@kitchen host kitchen.kitchcu.com
	handle @kitchen {
		reverse_proxy kitchen-web:80
	}

	@admin host admin.kitchcu.com
	handle @admin {
		reverse_proxy admin-web:80
	}

	@api host api.kitchcu.com
	handle @api {
		reverse_proxy gateway:8000
	}

	@media host media.kitchcu.com
	handle @media {
		reverse_proxy minio:9000
	}

	handle {
		respond "Unknown host" 404
	}
}
